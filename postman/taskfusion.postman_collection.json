{
  "info": {
    "name": "TaskFusion API",
    "description": "API collection for TaskFusion - Kanban Board and Image Annotation App",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user1@example.com\",\n    \"password\": \"SecurePass123!\",\n    \"password_confirm\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/accounts/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "accounts",
                "register",
                ""
              ]
            }
          }
        },
        {
          "name": "2. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.access) {",
                  "    pm.collectionVariables.set(\"access_token\", data.access);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user1@example.com\",\n    \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/accounts/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "accounts",
                "login",
                ""
              ]
            }
          }
        },
        {
          "name": "3. Get Profile (Me)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/accounts/me/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "accounts",
                "me",
                ""
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tasks (Kanban)",
      "item": [
        {
          "name": "List Tasks (Filter by Date)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/tasks/?selected_date=2026-07-03",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tasks",
                ""
              ],
              "query": [
                {
                  "key": "selected_date",
                  "value": "2026-07-03",
                  "description": "Filter by date"
                }
              ]
            }
          }
        },
        {
          "name": "Create Task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Build Postman Collection\",\n    \"priority\": \"HIGH\",\n    \"status\": \"TODO\",\n    \"selected_date\": \"2026-07-03\",\n    \"due_date\": \"2026-07-10\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tasks/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tasks",
                ""
              ]
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tasks/1/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tasks",
                "1",
                ""
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Annotations",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/annotations/images/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "annotations",
                "images",
                ""
              ]
            }
          }
        },
        {
          "name": "List Images",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/annotations/images/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "annotations",
                "images",
                ""
              ]
            }
          }
        },
        {
          "name": "Save Annotation (Polygon)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"image\": 1,\n    \"polygon_points\": [\n        {\"x\": 10, \"y\": 20},\n        {\"x\": 30, \"y\": 40},\n        {\"x\": 15, \"y\": 50}\n    ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/annotations/annotations/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "annotations",
                "annotations",
                ""
              ]
            }
          }
        },
        {
          "name": "Get Annotations by Image",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/annotations/annotations/?image=1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "annotations",
                "annotations",
                ""
              ],
              "query": [
                {
                  "key": "image",
                  "value": "1",
                  "description": "Image ID to filter by"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "access_token",
      "value": ""
    }
  ]
}
